# Copy to .env and fill in from your hosted Supabase project
# (Project Settings → API, and Project Settings → Database)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string — use the Session Pooler string from
# Project Settings → Database → Connection string (URI). Tests connect here directly.
SUPABASE_DB_URL=

# Project Settings → API → JWT Settings → JWT Secret.
# Used by the RLS test harness to mint HS256 tenant JWTs locally.
SUPABASE_JWT_SECRET=

# The single active tenant's UUID. Fixed by supabase/seed.sql; set after seeding.
# Nexus Demo Care Co. = 00000000-0000-0000-0000-000000000001
NEXUS_TENANT_ID=00000000-0000-0000-0000-000000000001

# The RLS probe tenant's UUID (second seeded tenant, for cross-tenant tests).
# RLS Probe Tenant = 00000000-0000-0000-0000-000000000002
NEXUS_PROBE_TENANT_ID=00000000-0000-0000-0000-000000000002

# The FastAPI backend connects as the RLS-subject `nexus_app` role (NEVER as
# postgres/service-role for data access). One-time ops step after `supabase db
# push` applies the app-role migration:
#   psql "$SUPABASE_DB_URL" -c "alter role nexus_app with password '<strong-pw>';"
# Then set this to the Session Pooler URI with username nexus_app.<project-ref>:
#   postgresql://nexus_app.<project-ref>:<pw>@<pooler-host>:5432/postgres
NEXUS_APP_DB_URL=

# Anthropic Messages API (chat) and Voyage AI (embeddings).
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# LangSmith observability. Leave blank to disable tracing (app runs fine without).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=nexus

# Static bearer token guarding the /mcp endpoint. MCP consumers are machines
# (Claude clients now, n8n nodes in M7), so /mcp deliberately keeps a static bearer
# rather than user auth — per-client OAuth waits for a real external need. Clients
# send it as `Authorization: Bearer <token>`. Leave blank to keep /mcp closed — an
# unset token 401s every request. Generate a random one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
NEXUS_MCP_TOKEN=

# Shared HMAC secret for the placeholder webhook ingress (/api/webhooks/{source}).
# Each source signs its raw body: X-Nexus-Signature = hex HMAC-SHA256(body).
# Leave blank to keep the ingress closed — an unset secret 401s every request.
# Real connectors bring their own per-platform verification, so this is a
# placeholder-phase convenience. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
NEXUS_WEBHOOK_SECRET=

# Cheap model for the automations `generate` step's "fast" option (Haiku-for-
# high-volume rule). Overridable like CHAT_MODEL; defaults to a Haiku model.
FAST_MODEL=claude-haiku-4-5-20251001

# Background engine loops (event dispatcher / cron / waker / recovery), run in the
# FastAPI lifespan. All optional — sensible defaults apply if unset.
#   ENABLED=false disables the loops entirely (the REST API + manual "run now" still
#   work); POLL_SECONDS is the cycle interval; STALE_MINUTES is how long a run may
#   sit in `running` before the recovery sweep re-advances it.
NEXUS_AUTOMATIONS_ENABLED=true
NEXUS_AUTOMATIONS_POLL_SECONDS=5
NEXUS_AUTOMATIONS_STALE_MINUTES=10

# Connector sync loop — the in-process poller for sources with NO webhooks
# (WelcomeHome today). Mirrors the automations-loop flags. ENABLED=false disables
# the loop entirely (the webhook ingress is unaffected); POLL_SECONDS is the cycle
# interval. A runner is active only when its own credentials are set, so an unset
# key simply means "no runner" — leaving these at their defaults is safe.
NEXUS_CONNECTORS_ENABLED=true
NEXUS_CONNECTORS_POLL_SECONDS=120

# WelcomeHome CRM (Module 18a). The account-scoped API token — sent as
# `Authorization: Token token={key}`. Unset ⇒ the WelcomeHome runner never
# registers and the sync loop is a no-op. COMMUNITY_ID "all" spans every community
# on the account (the single-community deployment can leave it as-is).
# BACKFILL_SINCE optionally bounds the one-time history import (scripts/
# backfill_welcomehome.py): an ISO date that limits BOTH how far back activities
# are pulled AND how far back Start-of-Care promotion reaches (see the README
# runbook — every historical start-of-care becomes an active client).
WELCOMEHOME_API_KEY=
WELCOMEHOME_BASE_URL=https://crm.welcomehomesoftware.com
WELCOMEHOME_COMMUNITY_ID=all
WELCOMEHOME_BACKFILL_SINCE=

# GoTo Connect (v1.2.0) — the phone system: inbound calls/SMS over a WebSocket
# notification channel, call transcripts into the communications tier, and real
# outbound SMS behind the gated send_sms tool. The runner and bridge activate only
# when CLIENT_ID + CLIENT_SECRET + REFRESH_TOKEN are all set; unset ⇒ no-op.
#
# One-time bootstrap (see the README runbook): register
# http://localhost:{GOTO_CONNECT_REDIRECT_PORT} as a redirect URI on the OAuth
# client, then run `python -m app.scripts.goto_oauth`, complete the browser
# consent, and paste the printed refresh token here. The authorization-code flow
# is mandatory — GoTo rejects client_credentials for this API surface (probed
# 2026-07-20), so there is no consent-free path.
GOTO_CONNECT_CLIENT_ID=
GOTO_CONNECT_CLIENT_SECRET=
GOTO_CONNECT_REFRESH_TOKEN=
GOTO_CONNECT_REDIRECT_PORT=8765

# The business line that sends outbound SMS. Leave blank to let the runner
# discover the account's line once and cache it in connector_state.
GOTO_CONNECT_LINE_ID=

# The office's own phone number, in E.164. Two jobs, both required for correct
# behaviour once the bridge is live:
#   * it is the "us" side of every call, so it is never treated as the person to
#     resolve against (an inbound call resolves on the CALLER, an outbound one on
#     the CALLEE — never on this number);
#   * it is the `ownerPhoneNumber` outbound SMS is sent from. `send_sms` refuses
#     to send at all when this is blank, rather than guessing a line.
GOTO_BUSINESS_NUMBER=+16303602784

# Known-numbers guard: comma-separated E.164 numbers whose call/SMS legs are
# plumbing, not correspondence — logged as receipts, never resolved to an entity
# or ingested as communications. WelcomeHome's provisional bridge number belongs
# here (a WH-initiated call dials the office through it first).
GOTO_IGNORED_NUMBERS=+13312811588

# ---------------------------------------------------------------------------
# Google Workspace (v1.3.0) — the authoritative source for email, plus calendar
# ---------------------------------------------------------------------------
# One-time setup, in this order (see backend/app/scripts/google_oauth.py):
#   1. GCP console -> enable the Gmail API AND the Google Calendar API.
#   2. Credentials -> OAuth client ID -> Web application.
#   3. Add http://localhost:{GOOGLE_REDIRECT_PORT} as an authorized redirect URI.
#   4. Fill in the id/secret below, then run:
#        python -m app.scripts.google_oauth
#      and paste the refresh token it prints.
# If the consent screen is in Testing mode, add the business account as a test
# user — and note that testing-mode refresh tokens expire after 7 days, so
# publish the app before relying on it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_PORT=8766

# Attachments larger than this are skipped rather than downloaded — an inbox is
# an uncontrolled input, and a 200 MB video has no business in the corpus.
GMAIL_ATTACHMENT_MAX_MB=10
