# Copy to frontend/.env and fill from your Supabase project (Project Settings -> API).
# These are the same values as the repo-root .env SUPABASE_URL / SUPABASE_ANON_KEY.
# The anon client sees zero rows until the app calls supabase.realtime.setAuth()
# with the token from GET /api/auth/realtime-token (dev seam; Module 6 -> real Auth).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
